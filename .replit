entrypoint = "main.py"
modules = ["python-3.11"]

[nix]
channel = "stable-25_05"

[unitTest]
language = "python3"

[gitHubImport]
requiredFiles = [".replit", "replit.nix"]

[deployment]
run = ["python3", "main.py"]
deploymentTarget = "cloudrun"

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main.py"

[workflows.workflow.metadata]
outputType = "console"

# ⚠️ SECRETS REMOVED — never store API keys in .replit (it is committed to git).
# Add every secret in the Replit "Secrets" tab (lock icon) instead. They are
# injected into the environment securely and are NOT committed.
# A local .env (git-ignored) mirrors them for off-Replit runs — see .env.example.

[[ports]]
localPort = 8080
externalPort = 80
