# ============================================================
# AKILI OS — Environment Template
# Copy to .env (local) or add each as a Replit Secret.
# NEVER commit the real .env file. .gitignore already blocks it.
# ============================================================

# ── Core (required) ──
TELEGRAM_TOKEN=
ANTHROPIC_API_KEY=
JUSTIN_CHAT_ID=

# ── Jarvis voice layer (NEW) ──
# ElevenLabs powers both speech-to-text (Scribe) and text-to-speech.
ELEVENLABS_API_KEY=
# Voice to speak replies in. Use a stock voice id or your own cloned voice id.
ELEVENLABS_VOICE_ID=
# "on"  = always reply with a voice note + text
# "auto"= reply with voice ONLY when Justin sent a voice note (default)
# "off" = text only
AKILI_VOICE_MODE=auto

# ── Music engine (NEW, optional) ──
# Path to ffmpeg binary for audio-only visualizer videos. Usually just "ffmpeg".
FFMPEG_BIN=ffmpeg

# ── Platform integrations (optional — unlock each as you go) ──
# Instagram (x4 accounts)
IG_USER_ID_JJ=
IG_PAGE_ID_JJ=
IG_TOKEN_JJ=
IG_USER_ID_CREOVA=
IG_PAGE_ID_CREOVA=
IG_TOKEN_CREOVA=
IG_USER_ID_SANKOFA=
IG_PAGE_ID_SANKOFA=
IG_TOKEN_SANKOFA=
IG_USER_ID_CREATIVE=
IG_PAGE_ID_CREATIVE=
IG_TOKEN_CREATIVE=

# Twitter / X
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BEARER_TOKEN=

# LinkedIn
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=
LINKEDIN_COMPANY_URN=

# Facebook / Meta
FB_PAGE_ID_JUSTIN=
FB_TOKEN_JUSTIN=
FB_PAGE_ID_CREOVA=
FB_TOKEN_CREOVA=

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_OPEN_ID=

# Snapchat
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=
SNAPCHAT_ACCESS_TOKEN=

# GitHub
GITHUB_TOKEN=

# Google / Gmail OAuth — paste the JSON contents as a single-line env var
# instead of committing the credential files.
GMAIL_PERSONAL_CREDENTIALS_JSON=
GMAIL_BUSINESS_CREDENTIALS_JSON=
